{
  "name": "wfsm-parser",
  "version": "2.0.0",
  "description": "WFSM 3D model file format parser and writer for WFS Engine — zero dependencies, browser + Node.js",
  "main": "wfsm-parser.js",
  "scripts": {
    "test":    "node -e \"const WFSM=require('./wfsm-parser.js');const b=WFSM.FileUtils.readNode('test_cube.wfsm');new WFSM.Parser(b).parse().then(r=>{const v=WFSM.TopologyUtils.validate(r.topologies[0]);console.log('Name:',r.meta.modelName);console.log('Vertices:',r.geometries[0].vertexCount);console.log('Topology:',v.valid?'VALID':'INVALID');console.log('All tests passed.');}).catch(e=>{console.error(e.message);process.exit(1);})\"",
    "example": "node wfsm-example.js"
  },
  "keywords": [
    "3d", "model", "wfsm", "parser", "writer",
    "wfs-engine", "firm-platform", "half-edge", "topology", "geometry"
  ],
  "author": "derrykervin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/derrykervin/WFSM-Format.git"
  },
  "homepage": "https://github.com/derrykervin/WFSM-Format#readme",
  "bugs": {
    "url": "https://github.com/derrykervin/WFSM-Format/issues"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "browser": "wfsm-parser.js",
  "files": [
    "wfsm-parser.js",
    "wfsm-example.js",
    "test_cube.wfsm",
    "README.md",
    "CHANGELOG.md"
  ]
}
